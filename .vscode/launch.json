            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "CMake: Build windows-clang-debug",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Windows Clang Debug (lldb, pde_tests)",
            "type": "lldb-dap",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/windows-clang-debug/pde_tests.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "debugAdapterPath": "C:/msys64/ucrt64/bin/lldb-dap.exe",
            "preLaunchTask": "CMake: Build windows-clang-debug"
        },
        {
            "name": "Linux GCC Debug (pde_tests)",
