            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "CMake: Build windows-clang-debug",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "Load Eigen pretty-printers (shared root)",
                    "text": "python import importlib.util; p=r'C:/install/eigen-pretty-printers/gdb/printers.py'; s=importlib.util.spec_from_file_location('eigen_printers', p); m=importlib.util.module_from_spec(s); s.loader.exec_module(m); m.register_eigen_printers(gdb)",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "Windows Clang Debug (lldb, pde_tests)",
            "type": "lldb-dap",
            "request": "launch",
            "program": "${workspaceFolder}/out/windows-clang-debug/pde_tests.exe",
            "args": [
                
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "EIGEN_PRINTERS_ROOT",
                    "value": "C:/install/eigen-pretty-printers"
                }
            ],
            "externalConsole": false,
            "debugAdapterPath": "C:/msys64/ucrt64/bin/lldb-dap.exe",
            "initCommands": [
                "command script import C:/install/eigen-pretty-printers/lldb/eigen_printers.py"
            ],
            "preLaunchTask": "CMake: Build windows-clang-debug"
        },
