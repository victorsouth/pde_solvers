{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Windows MSVC Debug (pde_tests)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/windows-msvc-debug/Debug/pde_tests.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: Build windows-msvc-debug"
        },
        {
            "name": "Windows GCC Debug (pde_tests)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/windows-gcc-debug/pde_tests.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "CMake: Build windows-gcc-debug",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Windows Clang Debug (gdb, pde_tests)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/windows-clang-debug/pde_tests.exe",
