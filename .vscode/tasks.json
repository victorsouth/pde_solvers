{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Build windows-msvc-debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "windows-msvc-debug"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build windows-gcc-debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "windows-gcc-debug"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "CMake: Build windows-clang-debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "windows-clang-debug"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
